    {
      "id": "shader-plasma",
      "title": "Plasma (audio-reactive)",
      "type": "shader",
      "audio": true,
      "source": "void mainImage(out vec4 o,in vec2 f){ vec2 uv=(2.0*f-iResolution.xy)/iResolution.y; float t=iTime*0.3+iLevel*1.5; float v=sin(uv.x*3.0+t)+sin(uv.y*4.0-t*1.2)+sin((uv.x+uv.y)*3.0+t); v+=iBass*3.0*sin(length(uv)*8.0-iTime*2.0); vec3 col=0.5+0.5*cos(vec3(0.0,2.0,4.0)+v+iTime*0.2); o=vec4(col,1.0); }",
      "tags": ["abstract", "audio"],
      "author": "WebDesk"
    },
    {
      "id": "shader-aurora",
      "title": "Aurora (audio-reactive)",
      "type": "shader",
      "audio": true,
      "source": "void mainImage(out vec4 o, in vec2 f){ vec2 uv=(f-0.5*iResolution.xy)/iResolution.y; float t=iTime*0.2; float a=0.0; for(float i=1.0;i<6.0;i++){ a+=sin(uv.x*i*3.0+t*i+iMid*4.0)/i; } float band=smoothstep(0.06,0.0,abs(uv.y-a*0.3-iBass*0.4)); vec3 col=mix(vec3(0.02,0.04,0.1),vec3(0.2,0.9,0.7),band); col+=band*iTreble*vec3(0.4,0.2,0.8); o=vec4(col,1.0); }",
      "tags": ["abstract", "audio"],
      "author": "WebDesk"
    },
